/*
 * ReSpeaker 8-Mic (6-Mic circular array) overlay for Raspberry Pi 5
 * Uses i2s_clk_consumer (Pi as I2S slave) - AC108 provides BCLK/LRCLK
 */
/dts-v1/;
/plugin/;

/ {
	compatible = "brcm,bcm2712";

	fragment@0 {
		target = <&i2s_clk_consumer>;
		__overlay__ {
			#sound-dai-cells = <0>;
			status = "okay";
		};
	};

	fragment@1 {
		target-path = "/";
		__overlay__ {
			ac10x_mclk: codec-mclk {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <24000000>;
			};
		};
	};

	fragment@2 {
		target = <&gpio>;
		__overlay__ {
			spk_amp_pins: spk_pins {
				brcm,pins = <17 22>;
				brcm,function = <1 0>;
				brcm,pull = <0 0>;
			};
			gpclk0_pins: gpclk0_pins {
				brcm,pins = <4>;
				brcm,function = <4>;
				brcm,pull = <0>;
			};
		};
	};

	fragment@3 {
		target = <&i2c1>;
		__overlay__ {
			#address-cells = <1>;
			#size-cells = <0>;
			status = "okay";

			ac101: ac101@1a {
				compatible = "x-power,ac101";
				pinctrl-names = "default";
				pinctrl-0 = <&spk_amp_pins &gpclk0_pins>;
				spk-amp-switch-gpios = <&gpio 17 0>;
				switch-irq-gpios = <&gpio 22 0>;
				reg = <0x1a>;
				#sound-dai-cells = <0>;
			};

			ac108_a: ac108@35 {
				compatible = "x-power,ac108_0";
				reg = <0x35>;
				#sound-dai-cells = <0>;
				data-protocol = <0>;
				tdm-chips-count = <2>;
			};

			ac108_b: ac108@3b {
				compatible = "x-power,ac108_1";
				reg = <0x3b>;
				#sound-dai-cells = <0>;
				data-protocol = <0>;
				tdm-chips-count = <2>;
			};
		};
	};

	fragment@4 {
		target = <&sound>;
		__overlay__ {
			compatible = "seeed-voicecard";
			seeed-voice-card,name = "seeed-8mic-voicecard";
			seeed-voice-card,channels-playback-override = <8>;
			seeed-voice-card,channels-capture-override  = <8>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "okay";

			seeed-voice-card,dai-link@0 {
				format = "dsp_a";
				bitclock-master = <&codec0_dai>;
				frame-master = <&codec0_dai>;
				reg = <0>;

				cpu {
					sound-dai = <&i2s_clk_consumer>;
					dai-tdm-slot-num     = <8>;
					dai-tdm-slot-width   = <32>;
					/* RP1 consumer mode: only 1 channel works; try full mask */
					dai-tdm-slot-tx-mask = <1 1 1 1 1 1 1 1>;
					dai-tdm-slot-rx-mask = <1 1 1 1 1 1 1 1>;
				};

				codec0_dai: codec {
					sound-dai = <&ac108_a>;
					clocks = <&ac10x_mclk>;
					system-clock-id = <1>;
				};
			};
		};
	};
};
