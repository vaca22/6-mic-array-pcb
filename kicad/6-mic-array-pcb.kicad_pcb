(kicad_pcb
  (version 20240108)
  (generator kicad)
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (1 "B.Cu" signal)
    (2 "In1.Cu" signal)
    (3 "In2.Cu" signal)
    (4 "F.Mask" mask)
    (5 "B.Mask" mask)
    (6 "F.SilkS" user)
    (7 "B.SilkS" user)
    (8 "F.Paste" mask)
    (9 "B.Paste" mask)
    (10 "Dwgs.User" user)
    (11 "Cmts.User" user)
    (12 "Eco1.User" user)
    (13 "Eco2.User" user)
    (14 "Edge.Cuts" user)
    (15 "Margin" user)
    (16 "B.CrtYd" user)
    (17 "F.CrtYd" user)
    (18 "B.Fab" user)
    (19 "F.Fab" user)
  )
  (setup
    (pad_to_mask_clearance 0.05)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros false)
      (usegerberextensions false)
      (usegerberattributes true)
      (usegerberadvancedattributes true)
      (creategerberjobfile true)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 6)
      (plotframeref false)
      (viasonmask false)
      (mode 1)
      (useauxorigin false)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups true)
      (pdf_back_fp_property_popups false)
      (dxfpolygonmode true)
      (dxfimperialunits true)
      (dxfusepcbnewfont true)
      (psnegative false)
      (psa4output false)
    )
  )
  (net 0 "")
  (net 1 "GND")
  (net 2 "3V3_DIG")
  (net 3 "3V3_ANA")
  (net 4 "I2S_BCLK")
  (net 5 "I2S_LRCLK")
  (net 6 "I2S_SDI")
  (net 7 "I2S_MCLK")
  (net 8 "MIC_BIAS")
  (net 9 "MIC1_OUT")
  (net 10 "MIC2_OUT")
  (net 11 "MIC3_OUT")
  (net 12 "MIC4_OUT")
  (net 13 "MIC5_OUT")
  (net 14 "MIC6_OUT")
  (net 15 "VBUS")
  (net 16 "DAC_P")
  (net 17 "DAC_N")

  (footprint "Package_LGA:LGA-56_6x6mm_P0.65mm" (layer "F.Cu")
    (at 100 80)
    (property "Reference" "U1")
    (property "Value" "SF32LB52JUD6")
    (property "Footprint" "Package_LGA:LGA-56_6x6mm_P0.65mm")
  )
  (footprint "Package_QFP:LQFP-48_7x7mm_P0.5mm" (layer "F.Cu")
    (at 180 80)
    (property "Reference" "U2")
    (property "Value" "ADAU1977")
    (property "Footprint" "Package_QFP:LQFP-48_7x7mm_P0.5mm")
  )
  (footprint "Microphone:MEMS_Mic_SMD_4.72x3.76mm" (layer "F.Cu")
    (at 40 60)
    (property "Reference" "MIC1")
    (property "Value" "SPW0442LR5H")
    (property "Footprint" "Microphone:MEMS_Mic_SMD_4.72x3.76mm")
  )
  (footprint "Microphone:MEMS_Mic_SMD_4.72x3.76mm" (layer "F.Cu")
    (at 60 60)
    (property "Reference" "MIC2")
    (property "Value" "SPW0442LR5H")
    (property "Footprint" "Microphone:MEMS_Mic_SMD_4.72x3.76mm")
  )
  (footprint "Microphone:MEMS_Mic_SMD_4.72x3.76mm" (layer "F.Cu")
    (at 80 60)
    (property "Reference" "MIC3")
    (property "Value" "SPW0442LR5H")
    (property "Footprint" "Microphone:MEMS_Mic_SMD_4.72x3.76mm")
  )
  (footprint "Microphone:MEMS_Mic_SMD_4.72x3.76mm" (layer "F.Cu")
    (at 40 40)
    (property "Reference" "MIC4")
    (property "Value" "SPW0442LR5H")
    (property "Footprint" "Microphone:MEMS_Mic_SMD_4.72x3.76mm")
  )
  (footprint "Microphone:MEMS_Mic_SMD_4.72x3.76mm" (layer "F.Cu")
    (at 60 40)
    (property "Reference" "MIC5")
    (property "Value" "SPW0442LR5H")
    (property "Footprint" "Microphone:MEMS_Mic_SMD_4.72x3.76mm")
  )
  (footprint "Microphone:MEMS_Mic_SMD_4.72x3.76mm" (layer "F.Cu")
    (at 80 40)
    (property "Reference" "MIC6")
    (property "Value" "SPW0442LR5H")
    (property "Footprint" "Microphone:MEMS_Mic_SMD_4.72x3.76mm")
  )
  (footprint "Package_TO_SOT_SMD:SOT-23" (layer "F.Cu")
    (at 220 60)
    (property "Reference" "U3")
    (property "Value" "XC6206P332MR")
    (property "Footprint" "Package_TO_SOT_SMD:SOT-23")
  )
  (footprint "Package_TO_SOT_SMD:SOT-23" (layer "F.Cu")
    (at 220 40)
    (property "Reference" "U4")
    (property "Value" "XC6206P332MR")
    (property "Footprint" "Package_TO_SOT_SMD:SOT-23")
  )
  (footprint "Connector_USB:USB_C_Receptacle_PCB" (layer "F.Cu")
    (at 260 80)
    (property "Reference" "J1")
    (property "Value" "USB-C-16P")
    (property "Footprint" "Connector_USB:USB_C_Receptacle_PCB")
  )

  (gr_line (start 0 0) (end 100 0) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 100 0) (end 100 120) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 100 120) (end 0 120) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 0 120) (end 0 0) (layer "Edge.Cuts") (width 0.05))

  (gr_text "6-Mic-Array-PCB" (at 50 110) (layer "F.SilkS")
    (effects (font (size 1.5 1.5) (thickness 0.3)))
  )
  (gr_text "SF32LB52 + ADAU1977" (at 50 100) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.25)))
  )
  (gr_text "v1.0 2026-03-04" (at 50 10) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.25)))
  )

  (zone
    (net 1)
    (net_name "GND")
    (layer "In1.Cu")
    (width 0.2)
    (hatch edge 0.5)
    (connect_pads (clearance 0.2))
    (min_thickness 0.2)
    (filled_areas_thickness no)
    (fill
      (thermal_gap 0.3)
      (thermal_bridge_width 0.3)
    )
    (polygon
      (pts
        (xy 5 5)
        (xy 95 5)
        (xy 95 115)
        (xy 5 115)
      )
    )
  )
)
