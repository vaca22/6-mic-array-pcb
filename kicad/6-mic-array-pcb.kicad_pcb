    (1 "B.Cu" signal)
    (2 "In1.Cu" signal)
    (3 "In2.Cu" signal)
    (4 "F.Mask" mask)
    (5 "B.Mask" mask)
    (6 "F.SilkS" user "F.Silkscreen")
    (7 "B.SilkS" user "B.Silkscreen")
